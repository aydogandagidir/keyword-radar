# Chrome Web Store publishing credentials for the cws-publish MCP server.
# Copy this file to ".env" in the same folder and fill in the values.
# ".env" is gitignored — never commit real secrets.

# OAuth 2.0 client (Google Cloud Console -> APIs & Services -> Credentials ->
# Create OAuth client ID -> Application type "Desktop app").
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=

# Long-lived refresh token obtained from the one-time OAuth consent flow.
# See README.md ("Getting a refresh token") for the exact steps.
CWS_REFRESH_TOKEN=

# The Chrome Web Store item id (looks like a 32-char string in the dashboard URL).
# Required for cws_get_status / cws_upload_package / cws_publish.
# Leave empty only when bootstrapping a brand-new item via cws_create_new_item.
CWS_EXTENSION_ID=

# Optional. Package to upload by default. If empty, the server uses the repo's
# release zip: release/bluedev-marketplace-keyword-radar-cws-0.1.0.zip
# A relative path is resolved against the repository root.
CWS_ZIP_PATH=
